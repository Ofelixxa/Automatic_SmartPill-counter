<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F7">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/bottomNav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#34C759"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mi Botiquín"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Registro y existencias"
                    android:textColor="#E5F9EB"
                    android:textSize="16sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:background="#FFFFFF">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Añadir Medicamento"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#1C1C1E"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NOMBRE DEL MEDICAMENTO"
                        android:textSize="12sp"
                        android:textColor="#8E8E93"
                        android:layout_marginBottom="8dp"/>

                    <EditText
                        android:id="@+id/inputNombreMedicamento"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@android:drawable/edit_text"
                        android:hint="Ej. Amoxicilina"
                        android:inputType="textCapWords"
                        android:textColor="#0d0c0c"
                        android:paddingHorizontal="12dp"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CANTIDAD EN CAJA"
                        android:textSize="12sp"
                        android:textColor="#8E8E93"
                        android:layout_marginBottom="8dp"/>

                    <EditText
                        android:id="@+id/inputCantidadMedicamento"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@android:drawable/edit_text"
                        android:hint="Ej. 30"
                        android:inputType="number"
                        android:textColor="#0d0c0c"
                        android:paddingHorizontal="12dp"
                        android:layout_marginBottom="20dp"/>

                    <Button
                        android:id="@+id/btnGuardarMedicamento"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Guardar Medicamento"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#34C759"
                        app:cornerRadius="12dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Existencias"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1C1C1E"
                android:layout_marginStart="20dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/contenedorExistencias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/navInicio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Inicio"
            android:gravity="center"
            android:textColor="#8E8E93"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/navBotiquin"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Botiquín"
            android:gravity="center"
            android:textColor="#34C759"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/navEscanear"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Escanear"
            android:gravity="center"
            android:textColor="#8E8E93"
            android:textStyle="bold"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>